# =============================================================================
# HayPlusbot environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# Phase 1 — required for the Next.js app to boot
# -----------------------------------------------------------------------------

# Public site URL — used as the base for auth email redirect links.
# In dev this is http://localhost:3000; in production set to the deployed domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# HayPlusbot Telegram channel — opened by the floating button on public pages.
NEXT_PUBLIC_TELEGRAM_CHANNEL_URL=https://t.me/hayplusbot

# Supabase project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — safe to expose to the browser; RLS enforces access
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — server-only. Bot worker and admin handlers only.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key — Claude Haiku for sentiment/narrative; cache aggressively
ANTHROPIC_API_KEY=

# Direct Postgres connection string — used by tests/ for savepoint-based
# trigger verification. Get from Supabase dashboard → Project Settings →
# Database → Connection string → URI (Session pooler 5432 or direct).
# Example: postgresql://postgres:PASS@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=

# -----------------------------------------------------------------------------
# Future phases — not needed for Phase 1
# -----------------------------------------------------------------------------

# MetaAPI.cloud token — single master account session in the bot worker
METAAPI_TOKEN=                          # not needed for Phase 1

# HFM Partner API — balance verification, IB referral checks
HFM_PARTNER_API_KEY=                    # not needed for Phase 1

# Twilio — SMS notifications (kept for future, not part of v3 launch)
TWILIO_ACCOUNT_SID=                     # not needed for Phase 1
TWILIO_AUTH_TOKEN=                      # not needed for Phase 1
TWILIO_PHONE_NUMBER=                    # not needed for Phase 1

# Resend — transactional email
RESEND_API_KEY=                         # not needed for Phase 1

# Finnhub — FX rates for USD-equivalent balance conversion (free tier)
FINNHUB_API_KEY=                        # not needed for Phase 1

# Trading Economics — fundamentals calendar polling (paid tier, 15-min)
TRADING_ECONOMICS_API_KEY=              # not needed for Phase 1

# Bootstrap admin email — first admin promoted via seed script
BOOTSTRAP_ADMIN_EMAIL=                  # not needed for Phase 1

# pgsodium master key — encrypts master_account_config.investor_password
PGSODIUM_KEY=                           # not needed for Phase 1
